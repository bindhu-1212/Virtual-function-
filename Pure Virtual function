#include<iostream>
using namespace std;
class Base
{
    int x=0;
    public:
  virtual void display()=0;
};
class Child :public Base
{
    int y =4;
    public:
    void display()
    {
        cout<<y;
    }
};
int main ()
{
    Base *b;
    Child c;
    b=&c;
    b->display();//call child class
    c.display();//call child class
}
