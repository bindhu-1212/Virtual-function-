#include<iostream>
using namespace std;
class Base
{
    int x=0;
    public:
  virtual void display()
  {
    cout<<x;
    // hiding base class and accessing child class
};
class Child :public Base
{
    int y =4;
    public:
    void display()
    {
        cout<<y;
    }
};
int main ()
{
    Base *b;
    Child c;
    b=&c;
    b->display(); // 4
    c.display();  //4
}
